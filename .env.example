# ============================================================
# Solar Pumps IoT Data Pipeline - Environment Variables
# ============================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ============================================================

# --- General ---
COMPOSE_PROJECT_NAME=solar-pumps-iot

# --- TimescaleDB / PostgreSQL ---
POSTGRES_USER=iot_user
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_DB=iot_data
TIMESCALEDB_PORT=5432

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=iot_user
RABBITMQ_DEFAULT_PASS=changeme_rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme_grafana
GRAFANA_PORT=3000

# --- Prometheus ---
PROMETHEUS_PORT=9090

# --- Flink ---
FLINK_JOBMANAGER_PORT=8081
